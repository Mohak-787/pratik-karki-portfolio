<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <main class="page auth-shell">
    <section class="panel">
      <div class="header">
        <div>
          <p class="hero-kicker">Access Portal</p>
          <h1 class="title-xl">Admin Login</h1>
          <p class="subtitle">Sign in to access contacts, video management, and upload workflows.</p>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success"><strong><%= success %></strong></div>
      <% } %>

      <% if (errors && errors.length) { %>
        <div class="alert alert-error">
          <strong>Login failed</strong>
          <ul>
            <% errors.forEach((error) => { %>
              <li><%= error.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form class="form" method="POST" action="/admin/login">
        <label>
          Work Email
          <input type="email" name="email" placeholder="admin@studio.com" value="<%= formData?.email || '' %>" required />
        </label>

        <label>
          Password
          <input type="password" name="password" placeholder="Enter secure password" required />
        </label>

        <div class="stack">
          <button type="submit" class="btn btn-primary">Login</button>
          <a class="btn btn-secondary" href="/admin/signup">Create Admin</a>
          <a class="btn btn-ghost" href="/contact">Contact Form</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
