<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Signup</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/js/auth-wave-background.js"></script>
</head>
<body class="auth-page">
  <div class="auth-bg" aria-hidden="true">
    <canvas class="auth-wave-canvas"></canvas>
  </div>
  <main class="page auth-shell">
    <section class="panel auth-panel">
      <div class="header">
        <div>
          <p class="hero-kicker">Access Setup</p>
          <h1 class="title-xl auth-title">Create Account</h1>
          <p class="subtitle auth-subtitle">Set up a new admin profile.</p>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success"><strong><%= success %></strong></div>
      <% } %>

      <% if (errors && errors.length) { %>
        <div class="alert alert-error">
          <strong>Signup failed</strong>
          <ul>
            <% errors.forEach((error) => { %>
              <li><%= error.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form class="form" method="POST" action="/admin/signup">
        <div class="row">
          <label>
            First name
            <input type="text" name="firstName" placeholder="First name" value="<%= formData?.firstName || '' %>" required />
          </label>

          <label>
            Last name
            <input type="text" name="lastName" placeholder="Last name" value="<%= formData?.lastName || '' %>" />
          </label>
        </div>

        <label>
          Work Email
          <input type="email" name="email" placeholder="admin@studio.com" value="<%= formData?.email || '' %>" required autocomplete="email" />
        </label>

        <label>
          Password
          <input type="password" name="password" placeholder="Minimum 6 characters" required autocomplete="new-password" />
        </label>

        <div class="stack auth-actions">
          <button type="submit" class="btn btn-primary auth-submit">Create Admin</button>
        </div>

        <p class="auth-switch">Already have an account? <a href="/admin/login">Login</a></p>
      </form>
    </section>
  </main>
</body>
</html>
