<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upload Video</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/js/auth-wave-background.js"></script>
  <script defer src="/js/logout-confirm.js"></script>
</head>
<body class="admin-home-page">
  <div class="auth-bg" aria-hidden="true">
    <canvas class="auth-wave-canvas"></canvas>
  </div>

  <header class="admin-home-nav-wrap">
    <nav class="admin-home-nav">
      <div class="admin-home-brand">
        <p class="hero-kicker">Admin Studio</p>
        <h1>Dashboard</h1>
      </div>

      <div class="admin-home-nav-links">
        <a class="btn btn-ghost" href="/admin/home">Home</a>
        <a class="btn btn-ghost" href="/admin/videos">Videos</a>
        <a class="btn btn-ghost" href="/admin/video">Upload</a>
        <a class="btn btn-ghost" href="/admin/contacts">Contacts</a>
      </div>

      <div class="admin-home-nav-user">
        <p class="metric">Signed in as <strong><%= admin?.name?.firstName || "Admin" %></strong></p>
        <form method="POST" action="/admin/logout" data-logout-confirm>
          <button type="submit" class="btn btn-secondary">Logout</button>
        </form>
      </div>
    </nav>
  </header>

  <main class="page admin-home-main">
    <section class="panel admin-home-panel">
      <div class="header">
        <div>
          <p class="hero-kicker">Upload Desk</p>
          <h1 class="title-xl">Add A New Video Asset</h1>
          <p class="subtitle">Ensure metadata quality before publishing to the client-facing side.</p>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success"><strong><%= success %></strong></div>
      <% } %>

      <% if (errors && errors.length) { %>
        <div class="alert alert-error">
          <strong>Fix the following issues:</strong>
          <ul>
            <% errors.forEach((error) => { %>
              <li><%= error.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form class="form" method="POST" action="/admin/video">
        <div class="row">
          <label>
            Video title
            <input type="text" name="title" placeholder="Product teaser cut v2" value="<%= formData?.title || '' %>" required />
          </label>
          <label>
            Category
            <select name="type" required>
              <option value="PRIMARY" <%= formData?.type === 'PRIMARY' ? 'selected' : '' %>>Primary</option>
              <option value="SECONDARY" <%= formData?.type !== 'PRIMARY' ? 'selected' : '' %>>Secondary</option>
            </select>
          </label>
        </div>

        <label>
          Video URL
          <input type="url" name="link" placeholder="https://..." value="<%= formData?.link || '' %>" required />
        </label>

        <label>
          Client / Project (Optional)
          <input type="text" name="client" placeholder="Acme Studio - Summer Campaign" value="<%= formData?.client || '' %>" />
        </label>

        <div class="stack">
          <button type="submit" class="btn btn-primary">Publish Video</button>
          <a class="btn btn-ghost" href="/admin/videos">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
