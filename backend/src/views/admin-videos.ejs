<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Videos</title>
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/js/auth-wave-background.js"></script>
  <script defer src="/js/logout-confirm.js"></script>
  <script defer src="/js/admin-videos.js"></script>
</head>
<body class="admin-home-page admin-videos-page">
  <div class="auth-bg" aria-hidden="true">
    <canvas class="auth-wave-canvas"></canvas>
  </div>

  <header class="admin-home-nav-wrap">
    <nav class="admin-home-nav">
      <div class="admin-home-brand">
        <p class="hero-kicker">Admin Studio</p>
        <h1>Dashboard</h1>
      </div>

      <div class="admin-home-nav-links">
        <a class="btn btn-ghost" href="/admin/home">Home</a>
        <a class="btn btn-ghost" href="/admin/videos">Videos</a>
        <a class="btn btn-ghost" href="/admin/video">Upload</a>
        <a class="btn btn-ghost" href="/admin/contacts">Contacts</a>
      </div>

      <div class="admin-home-nav-user">
        <p class="metric">Signed in as <strong><%= admin?.name?.firstName || "Admin" %></strong></p>
        <form method="POST" action="/admin/logout" data-logout-confirm>
          <button type="submit" class="btn btn-secondary">Logout</button>
        </form>
      </div>
    </nav>
  </header>

  <main class="page admin-home-main">
    <section class="panel admin-home-panel">
      <div class="header admin-videos-header">
        <div>
          <p class="hero-kicker">Library Console</p>
          <h1 class="title-xl">Video Catalog</h1>
          <p class="subtitle">Manage published assets by category and open links quickly during production review.</p>
        </div>
        <div class="filter-bar admin-videos-filter-bar">
          <div class="filter-group" role="tablist" aria-label="Video type filter">
            <button type="button" class="btn filter-btn active" data-filter="PRIMARY">Primary Only</button>
            <button type="button" class="btn filter-btn" data-filter="SECONDARY">Secondary Only</button>
          </div>
          <p class="metric" id="video-count">0 videos</p>
        </div>
      </div>

      <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
        <div class="alert alert-error">
          <strong>Unable to load videos</strong>
          <ul>
            <% errors.forEach((error) => { %>
              <li><%= error.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div id="video-grid" class="grid grid-3 admin-videos-grid"></div>
      <div id="video-empty" class="empty" style="display: none;">No videos available for this filter.</div>

      <script id="initial-videos" type="application/json"><%- JSON.stringify(videos || []).replace(/</g, "\\u003c") %></script>
    </section>
  </main>
</body>
</html>
