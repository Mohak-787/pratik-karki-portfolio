<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
  <script defer src="/js/theme.js"></script>
</head>
<body>
  <main class="page auth-shell">
    <section class="panel">
      <div class="header">
        <div>
          <p class="hero-kicker">Public Inquiry</p>
          <h1 class="title-xl">Contact Production Team</h1>
          <p class="subtitle">Send your project request or feedback. Admin can review this instantly in dashboard.</p>
        </div>
        <button type="button" class="btn btn-ghost btn-toggle" data-theme-toggle>Dark Mode</button>
      </div>

      <% if (success) { %>
        <div class="alert alert-success"><strong><%= success %></strong></div>
      <% } %>

      <% if (errors && errors.length) { %>
        <div class="alert alert-error">
          <strong>Unable to submit</strong>
          <ul>
            <% errors.forEach((error) => { %>
              <li><%= error.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form class="form" method="POST" action="/contact">
        <div class="row">
          <label>
            Name
            <input type="text" name="name" placeholder="Your full name" value="<%= formData?.name || '' %>" required />
          </label>

          <label>
            Email
            <input type="email" name="email" placeholder="you@company.com" value="<%= formData?.email || '' %>" required />
          </label>
        </div>

        <label>
          Phone (optional)
          <input type="text" name="phone" placeholder="Phone number" value="<%= formData?.phone || '' %>" />
        </label>

        <label>
          Message
          <textarea name="message" placeholder="Tell us what you need" required><%= formData?.message || '' %></textarea>
        </label>

        <div class="stack">
          <button type="submit" class="btn btn-primary">Send Message</button>
          <a class="btn btn-secondary" href="/admin/login">Admin Login</a>
          <a class="btn btn-ghost" href="/admin/signup">Admin Signup</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
